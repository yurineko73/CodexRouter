{
  "name": "codex-router",
  "version": "1.0.0",
  "description": "Codex Responses API → DeepSeek Chat Completions API 中转站",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "start:logger": "node .opencode/skills/logger/record-logger.js",
    "start:analyzer": "node .opencode/skills/logger/record-analyzer.js",
    "start:upgrader": "node .opencode/skills/logger/auto-upgrader.js",
    "fix:convert": "node .opencode/skills/git-operations/git-helper.js",
    "fix:clean": "bash .opencode/skills/file-cleanup/cleanup-script.sh .",
    "log:check": "node .opencode/skills/logger/record-logger.js",
    "doc:fix": "node .opencode/skills/doc-analysis/doc-fixer.js"
  },
  "keywords": [
    "codex",
    "deepseek",
    "proxy",
    "responses-api",
    "chat-completions"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "acorn": "^8.11.0",
    "chalk": "^4.1.2"
  },
  "devDependencies": {
    "eslint": "^8.50.0",
    "prettier": "^3.1.0"
  }
}
