# Codex Router 环境变量配置

# ── 必填 ──
# DeepSeek 或其他上游的 API Key
API_KEY=sk-your-deepseek-api-key

# ── 可选 ──
# 上游 API Base URL（默认 https://api.deepseek.com/v1）
UPSTREAM_BASE_URL=https://api.deepseek.com/v1

# 服务监听端口（默认 4446）
PORT=4446

# 默认模型名称（默认 deepseek-v4-flash）
DEFAULT_MODEL=deepseek-v4-flash

# 模型映射（JSON 格式，可选）
# 将 Codex 请求中的模型名映射到后端实际模型名
# MODEL_MAP={"o3":"deepseek-v4-flash","gpt-4o":"deepseek-v4-pro","codex-mini":"deepseek-v4-flash"}

# 日志级别（默认 info）
LOG_LEVEL=info
